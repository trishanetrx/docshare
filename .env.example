# Copy this file to .env and fill in real values before deploying

# Port the Express server listens on (use 3001 to avoid conflicts with other apps)
PORT=3001

# Strong random secret for JWT signing — generate with: openssl rand -hex 32
JWT_SECRET=change-me-to-a-long-random-string

# Directories (defaults are relative to project root)
# DATA_DIR=/root/docshare/data
# UPLOADS_DIR=/root/docshare/uploads

# Max upload size in MB (default 2500)
MAX_FILE_SIZE_MB=2500

# Optional: comma-separated origins to allow CORS from (leave unset for same-origin only)
# CORS_ORIGIN=https://otherdomain.com
